{
  "name": "moddle-context-serializer",
  "version": "5.0.0",
  "description": "Make bpmn-moddle context serializable and mapped to behaviour functions",
  "type": "module",
  "main": "./lib/main.cjs",
  "module": "./src/index.js",
  "browser": "./lib/main.cjs",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "require": "./lib/main.cjs",
      "import": "./src/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "test": "mocha",
    "posttest": "npm run lint && npm run typecheck && npm run dist && texample ./README.md,API.md",
    "test:lcov": "c8 -r lcov mocha && npm run lint",
    "cov:html": "c8 -r html -r text mocha",
    "lint": "eslint . --cache && prettier . -c --cache",
    "typecheck": "tsc -p tsconfig.check.json",
    "build:types": "dts-buddy",
    "dist": "rollup -c && npm run build:types",
    "prepack": "npm run dist"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/paed01/moddle-context-serializer.git"
  },
  "author": {
    "name": "Pål Edman",
    "url": "https://github.com/paed01"
  },
  "license": "MIT",
  "files": [
    "lib",
    "src",
    "types/index.d.ts",
    "types/index.d.ts.map"
  ],
  "keywords": [
    "bpmn",
    "bpmn 2",
    "serializable",
    "deserializable",
    "isomorphic"
  ],
  "peerDependencies": {
    "bpmn-moddle": ">=6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@types/bpmn-moddle": "^10.0.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "bpmn-elements": "^17.0.0",
    "bpmn-moddle": "^10.0.0",
    "bpmn-moddle-6": "npm:bpmn-moddle@6",
    "bpmn-moddle-7": "npm:bpmn-moddle@7",
    "bpmn-moddle-9": "npm:bpmn-moddle@9",
    "c8": "^11.0.0",
    "camunda-bpmn-moddle": "^7.0.1",
    "camunda-bpmn-moddle-6": "npm:camunda-bpmn-moddle@6",
    "chai": "^6.2.0",
    "dts-buddy": "^0.7.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "mocha": "^11.0.1",
    "prettier": "^3.2.5",
    "rollup": "^4.19.2",
    "texample": "^1.0.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    },
    "mocha": {
      "yargs": "^18.0.0"
    }
  }
}
