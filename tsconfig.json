{
  "include": ["src/**/*", "types"],
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "src",
    "lib": ["es2020"],
    "target": "es2020",
    "noErrorTruncation": true,
    "allowJs": true,
    "checkJs": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": false,
    "stripInternal": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node"],
    "paths": {
      "types": ["./types/interfaces.js"]
    }
  }
}
